---
import SiteLayout from "../layouts/SiteLayout.astro";
import { site } from "../data/site";

const base = import.meta.env.BASE_URL;
const avatarUrl = `${base}${site.avatar}`;

const featuredPost = {
  title: "我的第一篇博客",
  desc: "从 0 开始，我终于把博客真正搭上线了。这篇文章记录了我的开始，也记录了我第一次认真把一个属于自己的网页做出来。",
  href: `${base}posts/first-post/`,
};

const highlights = [
  "我正在把博客做成自己的作品",
  "我在练代码，也在练审美",
  "这个网站会持续进化",
  "这里会留下我的成长痕迹",
];

const stats = [
  { label: "当前风格", value: "多巴胺创意站" },
  { label: "个人状态", value: site.status },
  { label: "更新方向", value: "更酷的视觉体验" },
];

const cards = [
  {
    title: "我现在在学什么",
    text: "Git、GitHub、Astro、HTML、CSS，还有怎么让一个网页既好看又有自己的气质。",
  },
  {
    title: "这个博客会写什么",
    text: "学习笔记、建站过程、踩坑记录、页面设计尝试，以及我认真做成一件事之后的记录。",
  },
  {
    title: "我想把它做成什么样",
    text: "我想把这里做成一个有记忆点、有风格、有温度，别人一眼就能记住的个人博客。",
  },
];
---

<SiteLayout title="首页" description={site.intro}>
  <style>
    .hero {
      display: grid;
      grid-template-columns: 1.18fr 0.92fr;
      gap: 22px;
      margin-top: 8px;
    }

    .hero-main {
      padding: 44px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.08);
      font-size: 14px;
      font-weight: 800;
      color: #fff4c9;
    }

    .hero-title {
      margin: 18px 0 10px;
      font-size: clamp(56px, 9vw, 104px);
      line-height: 0.92;
      letter-spacing: -2px;
      font-weight: 900;
    }

    .hero-title span {
      background: linear-gradient(135deg, #ffffff, #ffd5ea, #ffd84d, #64eaff, #8b7cff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-subtitle {
      font-size: 24px;
      font-weight: 900;
      color: #fff1c2;
      margin-bottom: 14px;
    }

    .hero-desc {
      max-width: 720px;
      font-size: 18px;
      line-height: 1.95;
      color: var(--muted);
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 28px;
    }

    .hero-tags {
      margin-top: 22px;
    }

    .hero-note-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 24px;
    }

    .hero-note {
      padding: 16px 16px;
      border-radius: 20px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.05);
      font-weight: 700;
      color: #fff2fb;
    }

    .profile-panel {
      padding: 28px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 18px;
    }

    .profile-top {
      display: flex;
      gap: 16px;
      align-items: center;
    }

    .avatar-ring {
      width: 126px;
      height: 126px;
      padding: 4px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ff5fa2, #ffd84d, #64eaff, #8b7cff);
      box-shadow: 0 18px 40px rgba(255, 95, 162, 0.24);
      flex: 0 0 auto;
    }

    .avatar {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      display: block;
      object-fit: cover;
      background: #161b37;
    }

    .profile-name {
      font-size: 32px;
      font-weight: 900;
      margin-bottom: 6px;
    }

    .profile-role {
      color: #fff0c7;
      font-weight: 800;
      line-height: 1.7;
    }

    .profile-motto {
      padding: 18px 18px;
      border-radius: 22px;
      border: 1px solid var(--line);
      background: linear-gradient(
        135deg,
        rgba(255, 95, 162, 0.14),
        rgba(255, 216, 77, 0.1),
        rgba(100, 234, 255, 0.08)
      );
      font-size: 18px;
      line-height: 1.8;
      color: #fff6d6;
      font-weight: 800;
    }

    .profile-intro {
      color: var(--muted);
      line-height: 1.9;
    }

    .socials {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .social-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      border-radius: 14px;
      font-weight: 900;
      transition: 0.22s ease;
    }

    .social-link:hover {
      transform: translateY(-2px);
    }

    .social-mail {
      color: #1b1023;
      background: linear-gradient(135deg, #ffd84d, #ff9b42);
    }

    .social-github {
      color: white;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.05);
    }

    .profile-box {
      padding: 14px 16px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.05);
      color: #ffeef8;
      font-weight: 700;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin: 22px 0 28px;
    }

    .stat {
      padding: 18px;
      border-radius: 22px;
      border: 1px solid var(--line);
      background: linear-gradient(
        135deg,
        rgba(255, 95, 162, 0.12),
        rgba(255, 216, 77, 0.12),
        rgba(100, 234, 255, 0.1)
      );
      box-shadow: var(--shadow);
    }

    .stat-label {
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 24px;
      font-weight: 900;
    }

    .content-grid {
      display: grid;
      grid-template-columns: 1.08fr 0.92fr;
      gap: 22px;
    }

    .feature-card {
      padding: 28px;
    }

    .feature-badge {
      margin-bottom: 16px;
    }

    .feature-title {
      margin: 0 0 12px;
      font-size: 34px;
    }

    .feature-desc {
      color: var(--muted);
      line-height: 1.95;
      font-size: 17px;
    }

    .readmore {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 18px;
      color: #fff0c7;
      font-weight: 900;
    }

    .rainbow-line {
      height: 6px;
      margin-top: 22px;
      border-radius: 999px;
      background: linear-gradient(90deg, #ff5fa2, #ff9b42, #ffd84d, #64eaff, #8b7cff);
    }

    .mini-grid {
      display: grid;
      gap: 16px;
    }

    .mini-card {
      padding: 22px;
      border-radius: 24px;
      border: 1px solid var(--line);
      background: linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.08),
        rgba(255, 255, 255, 0.04)
      );
      box-shadow: var(--shadow);
      transition: 0.22s ease;
    }

    .mini-card:hover {
      transform: translateY(-3px);
    }

    .mini-card h3 {
      margin: 0 0 10px;
      font-size: 22px;
    }

    .mini-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.9;
    }

    @media (max-width: 960px) {
      .hero,
      .content-grid,
      .stats {
        grid-template-columns: 1fr;
      }

      .hero-main,
      .profile-panel,
      .feature-card {
        padding: 24px;
      }

      .hero-note-grid {
        grid-template-columns: 1fr;
      }

      .profile-top {
        flex-direction: column;
        align-items: flex-start;
      }

      .hero-title {
        letter-spacing: -1px;
      }
    }
  </style>

  <section class="hero">
    <article class="panel hero-main">
      <div class="hero-badge">创意首页 · 多巴胺升级版</div>

      <h1 class="hero-title">
        <span>{site.nickname}</span>
      </h1>

      <div class="hero-subtitle">{site.role}</div>

      <div class="hero-desc">{site.intro}</div>

      <div class="hero-actions">
        <a class="btn btn-primary" href={featuredPost.href}>阅读第一篇文章</a>
        <a class="btn btn-secondary" href={`${base}about/`}>进入 About 页面</a>
        <a class="btn btn-cyan" href={`mailto:${site.email}`}>联系我</a>
      </div>

      <div class="chip-list hero-tags">
        {site.tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>

      <div class="hero-note-grid">
        {highlights.map((item) => <div class="hero-note">{item}</div>)}
      </div>
    </article>

    <aside class="panel profile-panel">
      <div class="profile-top">
        <div class="avatar-ring">
          <img class="avatar" src={avatarUrl} alt={`${site.nickname} 的头像`} />
        </div>

        <div>
          <div class="profile-name">{site.nickname}</div>
          <div class="profile-role">{site.introShort}</div>
        </div>
      </div>

      <div class="profile-motto">{site.motto}</div>

      <div class="profile-intro">{site.intro}</div>

      <div class="socials">
        <a class="social-link social-mail" href={`mailto:${site.email}`}>📮 邮箱</a>
        <a
          class="social-link social-github"
          href={site.github}
          target="_blank"
          rel="noreferrer"
        >
          💻 GitHub
        </a>
      </div>

      <div class="profile-box">现在的位置：{site.location} · 状态：{site.status}</div>
    </aside>
  </section>

  <section class="stats">
    {
      stats.map((item) => (
        <div class="stat">
          <div class="stat-label">{item.label}</div>
          <div class="stat-value">{item.value}</div>
        </div>
      ))
    }
  </section>

  <h2 class="section-title">最近更新</h2>

  <section class="content-grid">
    <article class="panel feature-card">
      <div class="pill feature-badge">Featured Post</div>
      <h3 class="feature-title">{featuredPost.title}</h3>
      <div class="feature-desc">{featuredPost.desc}</div>
      <a class="readmore" href={featuredPost.href}>阅读全文 →</a>
      <div class="rainbow-line"></div>
    </article>

    <div class="mini-grid">
      {
        cards.map((card) => (
          <article class="mini-card">
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))
      }
    </div>
  </section>
</SiteLayout>